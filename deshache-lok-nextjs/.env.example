# GEMINI_API_KEY: Required for Gemini AI API calls.
# Used server-side only (in app/api/enhance/route.ts) — never exposed to the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL this app is hosted at.
# Used to build absolute Open Graph/Twitter URLs, sitemap.xml, and robots.txt.
# Set this to your Vercel deployment URL in production (e.g. https://your-app.vercel.app).
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Supabase (database) — server-only
# ---------------------------------------------------------------------------

# SUPABASE_URL: Your Supabase project URL (Project Settings → API → Project URL).
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: Project Settings → API → service_role key.
# This key bypasses Row Level Security — it is used server-side only
# (lib/supabase.ts) and must NEVER be prefixed with NEXT_PUBLIC_ or
# committed to source control.
SUPABASE_SERVICE_ROLE_KEY="MY_SUPABASE_SERVICE_ROLE_KEY"

# ---------------------------------------------------------------------------
# Firebase Auth — client SDK config (safe to expose in the browser bundle;
# NEXT_PUBLIC_ vars are baked into the client JS at build time)
# ---------------------------------------------------------------------------
# Firebase Console → Project Settings → General → Your apps → SDK setup and
# configuration → Config.

NEXT_PUBLIC_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abcdef"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXX"

# ---------------------------------------------------------------------------
# Firebase Admin — server-only, used to verify who's calling the API
# ---------------------------------------------------------------------------
# Firebase Console → Project Settings → Service Accounts → Generate new
# private key. That downloads a JSON file — copy the three fields below out
# of it. FIREBASE_PRIVATE_KEY must keep its literal \n sequences (most hosts,
# including Vercel, handle a multi-line env var fine if you paste it with
# quotes exactly as it appears in the JSON file).

FIREBASE_PROJECT_ID="your-project"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# SUPER_ADMIN_EMAILS: comma-separated list of emails that can see/edit/
# delete every article, not just their own. Server-only — never exposed to
# the client. Leave empty if nobody needs cross-author access.
# ---------------------------------------------------------------------------
SUPER_ADMIN_EMAILS="you@example.com"
